# External worktrees and toolchains.
/detools-dev/
/test-bench/Sensor-Watch/
/arm-gnu-toolchain-13.3.rel1-x86_64-arm-none-eabi/
/armgcc.tar.xz
/venv/
/AGENTS.md
/CLAUDE.md

# Top-level benchmark outputs; keep summary documents.
/artifacts/*
!/artifacts/*.md

# Python/cache noise.
**/__pycache__/
*.py[cod]
*$py.class

# Native and firmware build products.
/detools
/hy_dec
/hy_enc
*.o
*.a
*.so
*.d
*.map
*.elf
*.bin
*.hex
*.uf2
*.zst
*.xz

# The release gate corpus is tracked even though firmware binaries are ignored globally.
!/test-bench/images/
!/test-bench/images/**/
!/test-bench/images/**/*.bin
!/test-bench/images/**/*.elf
!/test-bench/fixtures/
!/test-bench/fixtures/**/
!/test-bench/fixtures/**/*.bin
!/test-bench/fixtures/**/*.elf
