# Top-level benchmark outputs; keep summary documents.
/artifacts/*
!/artifacts/*.md

# Local Python/cache noise.
/.venv/
/venv/
**/__pycache__/
*.py[cod]
*$py.class

# Native and firmware build products.
/.build/
/ultrapatch
*.o
*.a
*.so
*.d
*.map
*.elf
*.bin
*.hex
*.uf2
*.zst
*.xz

# Static firmware corpus.
!/test-bench/images/
!/test-bench/images/**/
!/test-bench/images/**/*.bin
!/test-bench/fixtures/
!/test-bench/fixtures/**/
!/test-bench/fixtures/**/*.bin
!/test-bench/foreign/
!/test-bench/foreign/**/
!/test-bench/foreign/**/*.bin
