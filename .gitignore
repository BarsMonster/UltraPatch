# Top-level benchmark outputs; keep summary documents.
/artifacts/*
!/artifacts/*.md

# Local Python/cache noise.
/.venv/
/venv/
**/__pycache__/
*.py[cod]
*$py.class

# Native and firmware build products.
/.build/
/ultrapatch
/test-bench/.wire-baseline-update.lock
/test-bench/.wire-baseline-update.transaction/
/test-bench/.wire-baseline-update.prepare.*/
/test-bench/.wire-baseline-update.done.*/
/.wire-baseline-update.recover.*
/test-bench/.wire-baseline-update.recover.*
*.o
*.a
*.so
*.d
*.map
*.elf
*.bin
*.hex
*.uf2
*.zst
*.xz

# The release gate corpus is tracked even though firmware binaries are ignored globally.
!/test-bench/images/
!/test-bench/images/**/
!/test-bench/images/**/*.bin
!/test-bench/images/**/*.elf
!/test-bench/fixtures/
!/test-bench/fixtures/**/
!/test-bench/fixtures/**/*.bin
!/test-bench/fixtures/**/*.elf
# Foreign lineage (third-party CircuitPython images) — tracked, provenance in foreign.sha256.
!/test-bench/foreign/
!/test-bench/foreign/**/
!/test-bench/foreign/**/*.bin
