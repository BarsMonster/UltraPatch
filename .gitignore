# Top-level benchmark outputs; keep summary documents.
/artifacts/*
!/artifacts/*.md

# Local Python/cache noise.
/.venv/
/venv/
**/__pycache__/
*.py[cod]
*$py.class

# Native and firmware build products.
/.build/
/ultrapatch
*.o
*.a
*.so
*.d
*.map
*.elf
*.bin
*.hex
*.uf2
*.zst
*.xz

# The source ELFs are tracked; their exact binaries are generated under the build profile.
!/test-bench/images/
!/test-bench/images/**/
!/test-bench/images/**/*.elf
!/test-bench/fixtures/
!/test-bench/fixtures/**/
!/test-bench/fixtures/**/*.elf
# Foreign lineage (third-party CircuitPython images) remains tracked.
!/test-bench/foreign/
!/test-bench/foreign/**/
!/test-bench/foreign/**/*.bin
# Focused non-product raw regression inputs remain tracked.
!/test-bench/regressions/
!/test-bench/regressions/**/
!/test-bench/regressions/**/*.bin
